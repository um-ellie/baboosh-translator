{
  "manifest_version": 3,
  "name": "Baboosh Translate",
  "version": "1.6.0",
  "description": "Pronounce and translate selected text using Google TTS (American accent).",
  "permissions": [
    "activeTab",
    "offscreen",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "src/assets/icon16.png",
    "32": "src/assets/icon32.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/style.css"
      ]
    }
  ],
  "action": {
    "default_title": "Baboosh Translate",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/icon16.png",
      "32": "src/assets/icon32.png",
      "48": "src/assets/icon48.png",
      "128": "src/assets/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/*.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}